import gradio as gr
import google.generativeai as genai
import os

# 1. API Key Connection - Settings-la 'GEMINI_API_KEY' nu add pannunga
api_key = os.environ.get("AIzaSyC_nbTAisBRxPNEI4hHGVaLvOzLNjyKMmU")

def mathes_ai_engine(message, history):
    if not api_key:
        return "❌ Error: API Key missing in Settings! Please add 'GEMINI_API_KEY'."
    
    try:
        # API-a configure panrom
        genai.configure(api_key=api_key)
        
        # AI-oda Character-a set panrom
        system_prompt = """
        You are 'Mathes AI', a world-class versatile AI assistant.
        - Tone: Intelligent, witty, and friendly.
        - Language: Reply in a natural mix of Tamil and English (Tanglish).
        - Skills: Expert in MA Economics, SSC/Govt Exam coaching, Cricket analysis, and Python coding.
        - Behavior: Give detailed and helpful answers like a supportive peer.
        """
        
        model = genai.GenerativeModel(
            model_name="gemini-1.5-flash",
            system_instruction=system_prompt
        )
        
        # AI kitta irundhu badhil vaangurom
        response = model.generate_content(message)
        return response.text
        
    except Exception as e:
        return f"⚠️ Oru error vandhuruchu: {str(e)}"

# --- UI DESIGN (Neat & Simple) ---
theme = gr.themes.Soft(primary_hue="blue")

with gr.Blocks(theme=theme, title="Mathes All-Rounder AI") as demo:
    gr.Markdown("# 🚀 Mathes All-Rounder AI")
    gr.Markdown("Economics | Career | Sports | Coding - Enna venaalum kelunga!")
    
    gr.ChatInterface(
        fn=mathes_ai_engine,
        examples=["MA Economics career options?", "CSK match status?", "Write a Python code for a game."],
        cache_examples=False,
    )

# App-a launch panrom
if __name__ == "__main__":
    demo.launch()
