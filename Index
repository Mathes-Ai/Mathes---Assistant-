import gradio as gr
import google.generativeai as genai
import os

# --- SAFE CONNECTION ---
# Settings-la neenga add panna 'GEMINI_API_KEY' name-a inga call panrom
api_key = os.environ.get("GEMINI_API_KEY")

def mathes_ai_engine(message, history):
    # API key load aagudha nu check panrom
    if not api_key:
        return "❌ Error: API Key missing! Settings -> Secrets-la 'AIzaSyC_nbTAisBRxPNEI4hHGVaLvOzLNjyKMmU' add pannunga."
    
    try:
        # Gemini AI configuration
        genai.configure(api_key=api_key)
        
        # System Instruction: This defines your AI's personality
        system_prompt = """
        You are 'Mathes AI', a world-class versatile AI assistant.
        - Personality: Intelligent, witty, and supportive.
        - Language: Reply in a natural mix of Tamil and English (Tanglish).
        - Skills: Expert in MA Economics (career & subject), SSC/Govt Exams, Cricket (IPL/CSK), and Python coding.
        - Behavior: Give clear, detailed, and professional answers.
        """
        
        model = genai.GenerativeModel(
            model_name="gemini-1.5-flash",
            system_instruction=system_prompt
        )
        
        # Generating AI response
        response = model.generate_content(message)
        return response.text
        
    except Exception as e:
        return f"⚠️ Exception Occurred: {str(e)}"

# --- UI DESIGN ---
theme = gr.themes.Soft(
    primary_hue="blue",
    secondary_hue="slate",
    font=[gr.themes.GoogleFont("Poppins"), "ui-sans-serif", "system-ui"],
)

with gr.Blocks(theme=theme, title="Mathes All-Rounder AI") as demo:
    gr.Markdown("# 🚀 Mathes All-Rounder AI")
    gr.Markdown("Economics | Career | Sports | Coding - Enna venaalum kelunga!")
    
    gr.ChatInterface(
        fn=mathes_ai_engine,
        examples=[
            "MA Economics career options?", 
            "CSK match analysis?", 
            "Write a Python code for a simple calculator."
        ],
        cache_examples=False,
    )

# App launch
if __name__ == "__main__":
    demo.launch()
