api_key = os.environ.get("AIzaSyC_nbTAisBRxPNEI4hHGVaLvOzLNjyKMmU")

if api_key:
    genai.configure(api_key=api_key)
    model = genai.GenerativeModel("gemini-1.5-flash")
else:
    model = None

# =========================================
# CORE FUNCTIONS
# =========================================

def ai_chat(message, history):
    if not model:
        return "❌ Error: API Key missing in Settings!"
    try:
        response = model.generate_content(message)
        return response.text
    except Exception as e:
        return f"⚠️ Error: {str(e)}"

def calculate(expression):
    try:
        # eval use pandradhu caution-ah irukanum, aana simple math-ku okay
        result = eval(expression)
        return f"✅ Result: {result}"
    except:
        return "❌ Invalid Calculation (Example: 5*5+10)"

def current_time():
    return datetime.now().strftime("%d-%m-%Y | %I:%M %p")

def random_quote():
    quotes = [
        "Dream big and work silently 🚀",
        "Consistency creates success 🔥",
        "Small progress matters 📚",
        "Your future needs your effort today 💪"
    ]
    return random.choice(quotes)

# =========================================
# UI DESIGN (MODERN LOOK)
# =========================================

with gr.Blocks(theme=gr.themes.Soft()) as demo:
    gr.Markdown("# 🚀 Mathes Ultimate AI Assistant")
    
    with gr.Tabs():
        # --- Tab 1: AI Chat ---
        with gr.TabItem("🤖 AI Chat"):
            gr.ChatInterface(fn=ai_chat)

        # --- Tab 2: Tools (Calculator & Time) ---
        with gr.TabItem("🛠 Tools"):
            with gr.Row():
                with gr.Column():
                    calc_input = gr.Textbox(label="Math Expression", placeholder="25 * 4")
                    calc_btn = gr.Button("Calculate")
                    calc_output = gr.Textbox(label="Result")
                with gr.Column():
                    time_btn = gr.Button("🕒 Get Current Time")
                    time_output = gr.Textbox(label="Time")
            
            calc_btn.click(calculate, inputs=calc_input, outputs=calc_output)
            time_btn.click(current_time, outputs=time_output)

        # --- Tab 3: Productivity (Notes & Motivation) ---
        with gr.TabItem("📝 Productivity"):
            quote_btn = gr.Button("✨ Get Motivation")
            quote_output = gr.Textbox(label="Daily Quote")
            quote_btn.click(random_quote, outputs=quote_output)
            
            gr.Markdown("---")
            note_input = gr.Textbox(label="Quick Note", placeholder="Write something...")
            note_btn = gr.Button("Save Note")
            note_output = gr.Textbox(label="Saved Content (Local Display)")
            note_btn.click(lambda x: x, inputs=note_input, outputs=note_output)

        # --- Tab 4: Resume Builder ---
        with gr.TabItem("📄 Resume"):
            r_name = gr.Textbox(label="Name")
            r_skills = gr.Textbox(label="Skills (Comma separated)")
            r_btn = gr.Button("Generate Simple Resume")
            r_out = gr.Markdown()
            
            def build_r(name, skill):
                return f"### Resume\n**Name:** {name}\n**Skills:** {skill}\n\n*Generated by Mathes AI*"
            
            r_btn.click(build_r, inputs=[r_name, r_skills], outputs=r_out)

# Launch with server settings
if __name__ == "__main__":
    demo.launch()
